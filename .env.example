# ============================================
# Portafolio Crimson & Ember — Variables de Entorno
# ============================================
# Copia este archivo como .env.local para desarrollo
# o configúralo en tu hosting (Vercel, etc.) para producción.
#
# IMPORTANTE: NUNCA subas .env.local o .env.production al repositorio.
# Este archivo (.env.example) es la única excepción.
# ============================================

# ====================
# ADMIN PANEL
# ====================

# Contraseña maestra para acceder al panel /admin.
# Esta es la ÚNICA variable obligatoria. Sin ella, el admin no funciona.
# Puedes usar cualquier string seguro como contraseña.
ADMIN_SECRET=tu-contraseña-super-segura

# ====================
# REPOSITORIO (OBLIGATORIO para auto-commit)
# ====================
# Tanto si usas OAuth como si usas PAT, el backend necesita saber
# en qué repositorio escribir. Estas variables son OBLIGATORIAS
# para que el auto-commit funcione.

GITHUB_OWNER=IDemonSan
GITHUB_REPO=mi-portafolio
# GITHUB_BRANCH=master
# ^ Solo si tu rama no es "main". Descomenta y cambia al nombre de tu rama.

# ====================
# OPCIÓN A: GITHUB OAUTH (recomendada)
# ====================
# Crea una OAuth App en GitHub:
#   Settings → Developer settings → OAuth Apps → New OAuth App
#
# Homepage URL: https://tu-dominio.com
# Authorization callback URL: https://tu-dominio.com/api/admin/github/callback
#
# Esta opción te permite conectar tu cuenta GitHub desde el panel admin
# con un solo clic. El token se guarda en una cookie httpOnly (7 días).

GITHUB_CLIENT_ID=tu-client-id
GITHUB_CLIENT_SECRET=tu-client-secret

# ====================
# OPCIÓN B: GITHUB TOKEN (alternativa al OAuth)
# ====================
# Crea un Personal Access Token (classic) desde:
#   GitHub Settings → Developer settings → Personal access tokens
# Requiere scope: 'repo' (para escribir en el repositorio).
#
# Con PAT no necesitas el flujo OAuth del navegador.
# El token no expira a menos que le pongas fecha de expiry.

# GITHUB_TOKEN=ghp_tu-token-personal

# ====================
# GITHUB USER-AGENT
# ====================
# Opcional. Identificador en el header User-Agent de las llamadas a GitHub API.
# Si no se define, se genera como GITHUB_OWNER/GITHUB_REPO.

# GITHUB_USER_AGENT=mi-portafolio/1.0

# ====================
# RATE LIMITING (admin panel)
# ====================
# Configuración por defecto del rate limiter (no requiere variables de entorno):
# - Login: 5 intentos por ventana de 15 min, bloqueo de 30 min
# - Save: 20 guardados por ventana de 15 min
#
# Los límites se reinician al hacer deploy (Vercel) o al reiniciar el servidor.
# No hay variables de entorno para esto — se configura en src/lib/rate-limiter.ts
